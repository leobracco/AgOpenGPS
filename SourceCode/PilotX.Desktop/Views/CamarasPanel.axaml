<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PilotX.Desktop.Views.CamarasPanel"
             Background="{StaticResource PilotXBgDeep}">
    <!--
        CamarasPanel — reemplazo nativo (parcial) de pages/camaras.html.

        Native (este panel): tab Monitor. Muestra hasta 4 camaras activas en
        layouts 1x1 / 2x1 / 2x2 con snapshot polling (JPEG over HTTP, igual
        que el camaras.js original). Doble click sobre una camara -> foco
        en 1x1 a esa camara.

        HTML via "Configurar": el tab Configuracion (edicion IP/usuario/
        clave/activa, agregar/borrar camara) sigue en HTML porque es un
        formulario con varios campos de texto que necesita el teclado
        virtual de la PWA — todavia no portado a Avalonia.

        Cadence: refrescoMs viene del /api/camaras/config (default 1000ms).
    -->
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" Margin="24,20,24,0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Camaras"
                           Foreground="{StaticResource PilotXTextHi}"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Name="Subtitle"
                           Text="Cargando..."
                           Foreground="{StaticResource PilotXTextDim}"
                           FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="StatusDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource PilotXTextDim}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Name="StatusText"
                                   Text="--"
                                   Foreground="{StaticResource PilotXTextMid}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Name="BtnConfigurar"
                        Content="Configurar"
                        MinHeight="40"
                        Padding="18,0,18,0"
                        Background="{StaticResource PilotXAccent}"
                        Foreground="{StaticResource PilotXBgDeep}"
                        FontWeight="SemiBold"
                        Click="OnConfigurarClick"/>
            </StackPanel>
        </Grid>

        <!-- ============ Layout switcher ============ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="24,14,24,0">
            <Button Name="BtnLay1x1" Content="1x1" Tag="1x1" Click="OnLayoutClick" MinHeight="38" Padding="14,0"/>
            <Button Name="BtnLay2x1" Content="2x1" Tag="2x1" Click="OnLayoutClick" MinHeight="38" Padding="14,0"/>
            <Button Name="BtnLay2x2" Content="2x2" Tag="2x2" Click="OnLayoutClick" MinHeight="38" Padding="14,0"/>
            <TextBlock Text="Doble click en una camara para enfocarla o volver."
                       Foreground="{StaticResource PilotXTextDim}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </StackPanel>

        <!-- ============ Grid de camaras ============ -->
        <Border Grid.Row="2"
                Margin="24,14,24,24"
                Background="{StaticResource PilotXBgMid}"
                BorderBrush="{StaticResource PilotXBorder}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="14,14,14,14">
            <Grid>
                <UniformGrid Name="CamGrid"
                             Columns="2" Rows="2"
                             IsVisible="False"/>
                <TextBlock Name="EmptyMsg"
                           Text="No hay camaras activas configuradas. Tocá Configurar para activarlas."
                           Foreground="{StaticResource PilotXTextDim}"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           IsVisible="True"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
