<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PilotX.Desktop.Views.CoreXEcuPanel"
             Background="{StaticResource PilotXBgDeep}">
    <!--
        CoreXEcuPanel - reemplazo nativo (Live tab only) de pages/corex-ecu.html.

        Cabin-info (no cabin-critical estricta — el operario no la mira manejando,
        pero es la referencia para diagnosticar al toque por que el guiado se
        movio raro). Polling 2Hz contra /api/corex-ecu/status mientras esta
        abierto. Cards: IMU, WAS, GPS, CAN Keya, Autosteer, Sistema.

        Las otras tabs (Estado / checklist, Calibracion / motor manual +
        barrido PWM Keya, Conexion / config con Teensy) NO estan portadas:
        el boton "Configurar" abre el WebView lazy sobre pages/corex-ecu.html —
        son flujos que se hacen parados en el galpon, no en cabina.

        Importante: NO se toca el firmware Teensy. Esto es solo la UI que lo
        observa via el Hub local.
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" Spacing="14">

            <!-- ============ Header ============ -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="CoreX-ECU"
                               Foreground="{StaticResource PilotXTextHi}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Name="SubtitleText"
                               Text="Telemetria del autosteer (Teensy)"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Pill: conexion con el ECU -->
                <Border Grid.Column="1"
                        Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="EcuDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource PilotXTextDim}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Name="EcuText"
                                   Text="sin datos"
                                   Foreground="{StaticResource PilotXTextMid}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="2"
                        Name="BtnConfigurar"
                        Content="Configurar"
                        Click="OnConfigurarClick"
                        Background="{StaticResource PilotXBgHigh}"
                        Foreground="{StaticResource PilotXTextHi}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,6,14,6"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Abre Estado / Calibracion / Conexion en el Hub"/>
            </Grid>

            <!-- ============ Error chip (oculto si ok) ============ -->
            <Border Name="ErrorChip"
                    Background="#2A1010"
                    BorderBrush="{StaticResource PilotXErr}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10,14,10"
                    IsVisible="False">
                <StackPanel Spacing="2">
                    <TextBlock Name="ErrorCode"
                               Foreground="{StaticResource PilotXErr}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               FontFamily="Consolas, Courier New, monospace"/>
                    <TextBlock Name="ErrorMsg"
                               Foreground="{StaticResource PilotXTextHi}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                    <TextBlock Name="ErrorTech"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="10"
                               TextWrapping="Wrap"
                               FontFamily="Consolas, Courier New, monospace"/>
                </StackPanel>
            </Border>

            <!-- ============ Grid de 6 cards ============ -->
            <UniformGrid Name="CardsHost" Columns="3" Rows="2"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
