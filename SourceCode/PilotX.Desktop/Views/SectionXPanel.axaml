<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PilotX.Desktop.Views.SectionXPanel"
             Background="{StaticResource PilotXBgDeep}">
    <!--
        SectionXPanel - reemplazo nativo (live-only) de pages/sectionx.html.

        Cabin-critical:
          - Pill de estado del SectionXBridge (semaforo del JS original)
          - KPI: secciones abiertas / total
          - Grilla de secciones con estado abierta/cerrada (consume HudSnapshot)

        El EDITOR de mapeo surcos->secciones + test de reles + debug MQTT NO
        esta portado: sigue en pages/sectionx.html. El boton "Configurar"
        abre el WebView lazy solo para esa pantalla.
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" Spacing="14">

            <!-- ============ Header ============ -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="SectionX"
                               Foreground="{StaticResource PilotXTextHi}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Control automatico de secciones"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Pill estado del bridge: red/yellow/green/gray -->
                <Border Grid.Column="1"
                        Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="BridgeDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource PilotXTextDim}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Name="BridgeText"
                                   Text="sin datos"
                                   Foreground="{StaticResource PilotXTextMid}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="2"
                        Name="BtnConfigurar"
                        Content="Configurar"
                        Click="OnConfigurarClick"
                        Background="{StaticResource PilotXBgHigh}"
                        Foreground="{StaticResource PilotXTextHi}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,6,14,6"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Abre el editor de mapeo en el Hub (surcos a secciones, test de reles)"/>
            </Grid>

            <!-- ============ KPI principal ============ -->
            <Border Background="{StaticResource PilotXBgMid}"
                    BorderBrush="{StaticResource PilotXBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,14,16,14">
                <StackPanel Spacing="6">
                    <TextBlock Text="Secciones del implemento"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom">
                        <TextBlock Name="KpiOpen" Text="--"
                                   Foreground="{StaticResource PilotXAccent}"
                                   FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="abiertas"
                                   Foreground="{StaticResource PilotXTextDim}"
                                   FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock Name="KpiTotal" Text="de --"
                                   Foreground="{StaticResource PilotXTextHi}"
                                   FontSize="14" Margin="6,0,0,8"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ============ Grilla de secciones (live) ============ -->
            <Border Background="{StaticResource PilotXBgMid}"
                    BorderBrush="{StaticResource PilotXBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,14,16,14">
                <StackPanel Spacing="10">
                    <TextBlock Text="Estado en vivo"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12" FontWeight="SemiBold"/>
                    <!--
                        Las celdas se generan dinamicamente desde codigo en
                        OnSnapshot: una por seccion del implemento.
                    -->
                    <ItemsControl Name="SectionsHost">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <TextBlock Name="EmptyHint"
                               Text="Sin job activo. Las secciones se muestran cuando arranca un trabajo."
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12"
                               IsVisible="True"/>
                </StackPanel>
            </Border>

            <TextBlock Text="El mapeo de surcos a secciones, test de reles y debug MQTT se editan en el Hub (boton Configurar)."
                       Foreground="{StaticResource PilotXTextDim}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
