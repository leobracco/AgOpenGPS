<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PilotX.Desktop.Views.NodosPanel"
             Background="{StaticResource PilotXBgDeep}">
    <!--
        NodosPanel — reemplazo nativo (parcial) de pages/nodos.html.

        Native (este panel): live monitor de nodos descubiertos en LAN/MQTT.
          - Header: titulo + pill broker (conectado/desconectado)
          - Banner de alarma: nodos del implemento activo offline
          - Tabs filtro: Pendientes / Aceptados / Off-line / Ignorados
          - Tabla: Estado · Alias/UID · Tipo · IP · FW · Ultima senal
          - Boton "Configurar": abre nodos.html via WebView lazy para:
            aceptar / ignorar / renombrar / restaurar / diagnostico MQTT /
            wildcard / msg log. Acciones de curado no caben tactil-bien
            sin diseno mas amplio + teclado virtual; quedan en HTML.

        Polling 3s (igual JS legacy /api/nodos/unified) cuando esta visible.
    -->
    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" Margin="24,20,24,0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Nodos"
                           Foreground="{StaticResource PilotXTextHi}"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Dispositivos AgroParallel descubiertos en la LAN"
                           Foreground="{StaticResource PilotXTextDim}"
                           FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Border Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="BrokerDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource PilotXTextDim}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Name="BrokerText"
                                   Text="Broker --"
                                   Foreground="{StaticResource PilotXTextMid}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6">
                    <TextBlock Name="ImplementoText"
                               Text="Implemento: --"
                               Foreground="{StaticResource PilotXTextMid}"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </Border>

                <Button Name="BtnConfigurar"
                        Content="Configurar"
                        MinHeight="40"
                        Padding="18,0,18,0"
                        Background="{StaticResource PilotXAccent}"
                        Foreground="{StaticResource PilotXBgDeep}"
                        FontWeight="SemiBold"
                        Click="OnConfigurarClick"/>
            </StackPanel>
        </Grid>

        <!-- ============ Banner alarma (offline del implemento activo) ============ -->
        <Border Grid.Row="1"
                Name="AlertBanner"
                IsVisible="False"
                Margin="24,14,24,0"
                Background="#1AC92D2D"
                BorderBrush="#8CC92D2D"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10,14,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Name="AlertTitulo"
                               Text="Nodos del implemento activo offline"
                               Foreground="#E15A5A"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock Name="AlertLista"
                               Text="—"
                               Foreground="#E2C7C7"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ Tabs ============ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="24,14,24,0">
            <Button Name="TabPendiente" Content="Pendientes" Click="OnTabClick" Tag="pendiente" MinHeight="42" Padding="18,0,12,0"/>
            <Button Name="TabAceptado"  Content="Aceptados"  Click="OnTabClick" Tag="aceptado"  MinHeight="42" Padding="18,0,12,0"/>
            <Button Name="TabOffline"   Content="Off-line"   Click="OnTabClick" Tag="offline"   MinHeight="42" Padding="18,0,12,0"/>
            <Button Name="TabIgnorado"  Content="Ignorados"  Click="OnTabClick" Tag="ignorado"  MinHeight="42" Padding="18,0,12,0"/>
        </StackPanel>

        <!-- ============ Tabla ============ -->
        <Border Grid.Row="3"
                Margin="24,14,24,24"
                Background="{StaticResource PilotXBgMid}"
                BorderBrush="{StaticResource PilotXBorder}"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="0">
                    <!-- Header de tabla -->
                    <Grid ColumnDefinitions="120,*,120,140,140,160"
                          Background="{StaticResource PilotXBgHigh}">
                        <TextBlock Grid.Column="0" Text="Estado"        Padding="12,10,8,10" Foreground="{StaticResource PilotXTextDim}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Alias / UID"   Padding="12,10,8,10" Foreground="{StaticResource PilotXTextDim}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Tipo"          Padding="12,10,8,10" Foreground="{StaticResource PilotXTextDim}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="IP"            Padding="12,10,8,10" Foreground="{StaticResource PilotXTextDim}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="FW"            Padding="12,10,8,10" Foreground="{StaticResource PilotXTextDim}" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="Ultima senal"  Padding="12,10,12,10" Foreground="{StaticResource PilotXTextDim}" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Filas dinamicas -->
                    <StackPanel Name="FilasList" Spacing="0">
                        <TextBlock Name="EmptyMsg"
                                   Text="No hay nodos en esta vista."
                                   Padding="14,18,14,18"
                                   Foreground="{StaticResource PilotXTextDim}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
