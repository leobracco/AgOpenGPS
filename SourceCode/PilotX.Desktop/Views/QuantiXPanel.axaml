<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PilotX.Desktop.Views.QuantiXPanel"
             Background="{StaticResource PilotXBgDeep}">
    <!--
        QuantiXPanel - reemplazo nativo (Monitor live-only) de pages/quantix.html.

        Cabin-critical: ver dosis real vs objetivo + PWM + estado PID por motor
        de cada nodo QuantiX que este publicando telemetria. Se actualiza a 2Hz
        contra /api/quantix/live mientras esta abierto.

        Las otras tabs del HTML (Motores CRUD, Shape upload, PID live-tune,
        Calibracion, Prueba) NO estan portadas: el boton "Configurar" abre el
        WebView lazy sobre pages/quantix.html — son flujos que se editan en el
        galpon, no manejando.
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" Spacing="14">

            <!-- ============ Header ============ -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="QuantiX"
                               Foreground="{StaticResource PilotXTextHi}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Control PID - 2 motores por nodo"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Pill: cuantos nodos esta viendo -->
                <Border Grid.Column="1"
                        Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="NodosDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource PilotXTextDim}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Name="NodosText"
                                   Text="-- nodos"
                                   Foreground="{StaticResource PilotXTextMid}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="2"
                        Name="BtnConfigurar"
                        Content="Configurar"
                        Click="OnConfigurarClick"
                        Background="{StaticResource PilotXBgHigh}"
                        Foreground="{StaticResource PilotXTextHi}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,6,14,6"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Abre Motores / Shape / PID / Calibracion / Prueba en el Hub"/>
            </Grid>

            <!-- ============ Lista de nodos (live) ============ -->
            <!--
                Cada nodo es una seccion con N motor-cards en horizontal.
                Construido dinamicamente desde codigo en cada tick (2Hz).
            -->
            <StackPanel Name="NodosHost" Spacing="14"/>

            <TextBlock Name="EmptyHint"
                       Text="No se ven nodos QuantiX en la LAN. Verifica que el broker MQTT (CoreX/AgIO) este corriendo y los ESP32 conectados."
                       Foreground="{StaticResource PilotXTextDim}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       IsVisible="True"/>

            <TextBlock Text="El CRUD de motores, upload de shape de dosis, tuning PID, calibracion y pruebas se editan en el Hub (boton Configurar)."
                       Foreground="{StaticResource PilotXTextDim}"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
