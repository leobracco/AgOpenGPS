<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PilotX.Desktop.Views.GpsDataPanel"
             Background="{StaticResource PilotXBgDeep}">
    <!--
        GpsDataPanel - reemplazo nativo de pages/datos-gps.html.

        Equivalente al popup FormGPSData de PilotX legacy: vel, rumbo,
        cardinal, lat/lon, easting/northing locales + datos de equipo.
        Todos los valores salen del HudSnapshot — sin red propia.
    -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" Spacing="14">

            <!-- ============ Header ============ -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Antena GPS"
                               Foreground="{StaticResource PilotXTextHi}"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Posicion actual del tractor y calidad de la senal"
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="12"/>
                </StackPanel>

                <!-- Pill de estado (sin fix / fix ok / en trabajo) -->
                <Border Grid.Column="1"
                        Background="{StaticResource PilotXBgHigh}"
                        BorderBrush="{StaticResource PilotXBorderHigh}"
                        BorderThickness="1"
                        CornerRadius="999"
                        Padding="14,6,14,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse Name="EstadoDot"
                                 Width="10" Height="10"
                                 Fill="{StaticResource PilotXTextDim}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Name="EstadoText"
                                   Text="Sin fix"
                                   Foreground="{StaticResource PilotXTextMid}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============ KPIs principales (velocidad + rumbo) ============ -->
            <UniformGrid Columns="2" Rows="1">
                <Border Background="{StaticResource PilotXBgMid}"
                        BorderBrush="{StaticResource PilotXBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,14,16,14"
                        Margin="0,0,8,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Velocidad"
                                   Foreground="{StaticResource PilotXTextDim}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                            <TextBlock Name="KpiVel"
                                       Text="--"
                                       Foreground="{StaticResource PilotXTextHi}"
                                       FontSize="40"
                                       FontWeight="Bold"/>
                            <TextBlock Text="km/h"
                                       Foreground="{StaticResource PilotXTextDim}"
                                       FontSize="16"
                                       Margin="0,0,0,8"/>
                        </StackPanel>
                        <TextBlock Text="Promedio del ultimo segundo"
                                   Foreground="{StaticResource PilotXTextDim}"
                                   FontSize="11"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource PilotXBgMid}"
                        BorderBrush="{StaticResource PilotXBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,14,16,14"
                        Margin="8,0,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Rumbo"
                                   Foreground="{StaticResource PilotXTextDim}"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Bottom">
                            <TextBlock Name="KpiHeading"
                                       Text="--"
                                       Foreground="{StaticResource PilotXTextHi}"
                                       FontSize="40"
                                       FontWeight="Bold"/>
                            <TextBlock Text="°"
                                       Foreground="{StaticResource PilotXTextDim}"
                                       FontSize="20"
                                       Margin="0,0,0,8"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Direccion"
                                       Foreground="{StaticResource PilotXTextDim}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <TextBlock Name="KpiCardinal"
                                       Text="--"
                                       Foreground="{StaticResource PilotXTextHi}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ============ Coordenadas ============ -->
            <TextBlock Text="Coordenadas"
                       Foreground="{StaticResource PilotXTextHi}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,4,0,0"/>
            <Border Background="{StaticResource PilotXBgMid}"
                    BorderBrush="{StaticResource PilotXBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18,4,18,4">
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Latitud"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="KpiLat" Text="--"
                                   FontFamily="Consolas,Menlo,monospace"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource PilotXBorder}"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Longitud"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="KpiLon" Text="--"
                                   FontFamily="Consolas,Menlo,monospace"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource PilotXBorder}"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Easting (local)"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="KpiEast" Text="--"
                                   FontFamily="Consolas,Menlo,monospace"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource PilotXBorder}"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Northing (local)"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="KpiNorth" Text="--"
                                   FontFamily="Consolas,Menlo,monospace"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ============ Equipo ============ -->
            <TextBlock Text="Equipo"
                       Foreground="{StaticResource PilotXTextHi}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,4,0,0"/>
            <Border Background="{StaticResource PilotXBgMid}"
                    BorderBrush="{StaticResource PilotXBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18,4,18,18">
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Vehiculo"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="DetVehiculo" Text="--"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource PilotXBorder}"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Ancho de herramienta"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="DetAncho" Text="-- m"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource PilotXBorder}"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Secciones"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="DetSec" Text="--"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource PilotXBorder}"/>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
                        <TextBlock Grid.Column="0" Text="Trabajo en curso"
                                   Foreground="{StaticResource PilotXTextMid}" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="DetJob" Text="--"
                                   Foreground="{StaticResource PilotXTextHi}" FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Para cambiar la altura de la antena, el offset lateral u otros parametros del montaje, ingresa a la configuracion del piloto desde la UI nativa de PilotX (boton Vehiculo)."
                               Foreground="{StaticResource PilotXTextDim}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
